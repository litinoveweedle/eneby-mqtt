[LOGGING]
LEVEL = info

[MQTT]
TOPIC = speaker_living
SERVER = 192.168.1.1
PORT = 1883
QOS = 1
TIMEOUT = 5
USER = mqttuser
PASS = mqttpass
BIRTH_TOPIC = homeassistant/status

[GPIO]
#raspberry PINs
POWER =  13
VOL_UP = 6
VOL_DW = 19
BT_LED = 16
AUX_LED = 12

[VOLUME]
MAXIMUM = 40
DEFAULT = 15
INITIAL = 30

[RUNTIME]
TELE_INTERVAL = 300
MAX_ERROR = 0
RESTART_DELAY = 15
